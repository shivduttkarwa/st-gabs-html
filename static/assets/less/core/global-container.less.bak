/* ============================================================
   GLOBAL CONTAINER — one horizontal rhythm site-wide
   (aligned with wcc: fluid max-width + padding only)
   Loaded after Bootstrap so these rules win.
   ============================================================ */

:root {
  --sg-container-padding-x: 1rem;
}

/* Match previous site gutters: 5rem (~80px) each side from lg up */
@media (min-width: 992px) {
  :root {
    --sg-container-padding-x: 5rem;
  }
}

.container,
.container-fluid {
  width: 100%;
  max-width: 100%;
  margin-left: auto;
  margin-right: auto;
  padding-left: var(--sg-container-padding-x);
  padding-right: var(--sg-container-padding-x);
  /* Side inset is independent; keep default-ish column gutters */
  --bs-gutter-x: 1.5rem;
  --bs-gutter-y: 0;
}
